# ── .env.example ─────────────────────────────────────────────────────────
# This is a TEMPLATE file — safe to push to GitHub
# Copy this file, rename it to .env and add your real keys
#
# Command:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────


# ── Groq API Key (Required) ───────────────────────────────────────────────
# Get your FREE key at: https://console.groq.com
# Steps: Sign Up → API Keys → Create New Key → Copy & Paste below

GROQ_API_KEY=your_groq_api_key_here


# ── App Settings (Optional) ───────────────────────────────────────────────
APP_TITLE=AI Trading Assistant
APP_ENV=development
DEBUG=False